      background-position: right 0.9rem center;
      background-size: 16px;
      padding-right: 2.5rem;
    }

    .form-submit {
      margin-top: 1.5rem;
    }

    .form-submit .btn {
      width: 100%;
      justify-content: center;
      font-size: 1rem;
      padding: 0.95rem;
    }

    .form-note {
      margin-top: 0.75rem;
      font-size: 0.78rem;
      color: #aaa;
      text-align: center;
      max-width: none;
