  <script>
  (function(){
    /* ── Voor & Na slider ── */
    (function() {
      const projects = [
        { name: 'Tuin-make-over',  before: 'img/portfolio/terras-makeover-voor.jpg', after: 'img/portfolio/terras-makeover.jpg', thumb: 'img/portfolio/terras-makeover.jpg' },
        { name: 'Bestrate binnenplaats', before: 'img/portfolio/oprit-aanleg.jpg', after: 'img/portfolio/oprit-klinkers.jpg', thumb: 'img/portfolio/oprit-klinkers.jpg' },
      ];
      let pct = 50, dragging = false, hintHidden = false;
      const wrap    = document.getElementById('vnaWrap');
      const before  = document.getElementById('vnaBefore');
      const after   = document.getElementById('vnaAfter');
      const divider = document.getElementById('vnaDivider');
      const skeleton= document.getElementById('vnaSkeleton');
      const hint    = document.getElementById('vnaHint');
      const list    = document.getElementById('vnaProjects');
      if (!wrap) return;

      function apply(x) {
        const r = wrap.getBoundingClientRect();
        pct = Math.min(100, Math.max(0, ((x - r.left) / r.width) * 100));
        after.style.clipPath = `inset(0 0 0 ${pct.toFixed(2)}%)`;
        divider.style.left   = pct.toFixed(2) + '%';
      }
      function hideHint() { if (!hintHidden) { hintHidden=true; hint.classList.add('hidden'); } }
      wrap.addEventListener('mousedown', e => { dragging=true; apply(e.clientX); hideHint(); });
      window.addEventListener('mousemove', e => { if (dragging) apply(e.clientX); });
      window.addEventListener('mouseup', () => { dragging=false; });
      wrap.addEventListener('touchstart', e => { dragging=true; apply(e.touches[0].clientX); hideHint(); }, {passive:true});
      window.addEventListener('touchmove', e => { if (dragging) apply(e.touches[0].clientX); }, {passive:true});
      window.addEventListener('touchend', () => { dragging=false; });

      function load(i) {
        const p = projects[i]; let n = 0;
        skeleton.classList.remove('gone');
        pct=50; after.style.clipPath='inset(0 0 0 50%)'; divider.style.left='50%';
        function onLoaded() { if (++n>=2) skeleton.classList.add('gone'); }
        before.onload=onLoaded; after.onload=onLoaded;
        before.src=p.before; after.src=p.after;
        // Cached images won't fire onload — check immediately
        if (before.complete) onLoaded();
        if (after.complete) onLoaded();
        // Fallback: hide skeleton after 3s regardless
        setTimeout(() => skeleton.classList.add('gone'), 3000);
        list.querySelectorAll('.vna-project-btn').forEach((b,j)=>b.classList.toggle('active',j===i));
      }
      projects.forEach((p,i) => {
        const btn = document.createElement('button');
        btn.className = 'vna-project-btn' + (i===0?' active':'');
        btn.innerHTML = `<img src="${p.thumb}" alt="${p.name}" loading="lazy"><span>${p.name}</span>`;
        btn.addEventListener('click', () => load(i));
        list.appendChild(btn);
      });
      load(0);
    })();

    /* ===== FILTER ===== */
    const filterBtns = document.querySelectorAll('.filter-btn');
    const items      = document.querySelectorAll('.masonry-item');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.dataset.filter;
        items.forEach(item => {
          const match = cat === 'all' || item.dataset.cat === cat;
          item.classList.toggle('hidden', !match);
        });
      });
    });

    /* ===== LIGHTBOX (masonry) ===== */
    const lightbox      = document.getElementById('lightbox');
    const lightboxImg   = document.getElementById('lightbox-img');
    const lightboxCap   = document.getElementById('lightbox-caption');
    const lightboxCount = document.getElementById('lightbox-counter');
    const lightboxThumbs= document.getElementById('lightbox-thumbs');
    const lbClose       = document.getElementById('lightbox-close');
    const lbPrev        = document.getElementById('lightbox-prev');
    const lbNext        = document.getElementById('lightbox-next');

    let lbItems  = [];
    let lbCurrent = 0;

    function buildLbItems() {
      lbItems = Array.from(document.querySelectorAll('.masonry-item:not(.hidden)'));
      lightboxThumbs.innerHTML = '';
      lbItems.forEach((item, i) => {
        const src = item.querySelector('img').src;
        const alt = item.querySelector('img').alt;
        const th  = document.createElement('div');
        th.className = 'lightbox-thumb';
        th.innerHTML = `<img src="${src}" alt="${alt}">`;
        th.addEventListener('click', () => lbGo(i));
        lightboxThumbs.appendChild(th);
      });
    }

    function lbGo(index) {
      lbCurrent = (index + lbItems.length) % lbItems.length;
      const item = lbItems[lbCurrent];
      const img  = item.querySelector('img');
      lightboxImg.classList.add('lb-loading');
      lightboxImg.onload = () => lightboxImg.classList.remove('lb-loading');
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightboxCap.textContent   = item.dataset.lightbox || '';
      lightboxCount.textContent = `${lbCurrent + 1} / ${lbItems.length}`;
      lightboxThumbs.querySelectorAll('.lightbox-thumb').forEach((t, i) =>
        t.classList.toggle('active', i === lbCurrent)
      );
    }

    function openLb(index) {
      buildLbItems();
      lbGo(index);
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeLb() {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    }

    items.forEach((item, i) => {
      item.addEventListener('click', () => {
        const visible = Array.from(document.querySelectorAll('.masonry-item:not(.hidden)'));
        openLb(visible.indexOf(item));
      });
    });

    lbClose.addEventListener('click', closeLb);
    lbPrev.addEventListener('click',  () => lbGo(lbCurrent - 1));
    lbNext.addEventListener('click',  () => lbGo(lbCurrent + 1));
    lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLb(); });

    document.addEventListener('keydown', e => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape')     closeLb();
      if (e.key === 'ArrowLeft')  lbGo(lbCurrent - 1);
      if (e.key === 'ArrowRight') lbGo(lbCurrent + 1);
    });

    let lbTouchX = 0;
    lightbox.addEventListener('touchstart', e => { lbTouchX = e.touches[0].clientX; }, { passive: true });
    lightbox.addEventListener('touchend',   e => {
      const diff = lbTouchX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) lbGo(diff > 0 ? lbCurrent + 1 : lbCurrent - 1);
    });
  })();
  </script>
